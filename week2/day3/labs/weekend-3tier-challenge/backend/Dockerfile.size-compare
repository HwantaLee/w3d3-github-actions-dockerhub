ARG BASE_IMAGE=node:22-alpine
FROM ${BASE_IMAGE}
RUN if command -v apk >/dev/null 2>&1; then apk add --no-cache iputils busybox-extras; \
    elif command -v apt-get >/dev/null 2>&1; then apt-get update && apt-get install -y --no-install-recommends iputils-ping netcat-openbsd && rm -rf /var/lib/apt/lists/*; \
    fi
WORKDIR /app
COPY server.js .
EXPOSE 8080
CMD ["node", "server.js"]
